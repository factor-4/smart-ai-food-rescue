# Local .terraform directories
**/.terraform/*

# .tfstate files (contain secrets and resource IDs)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable definition files (may contain sensitive values)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc